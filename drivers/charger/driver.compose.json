{
  "name": {
    "en": "Car charger",
    "nl": "Autolader"
  },
  "class": "evcharger",
  "capabilities": [
    "measure_power",
    "evcharger_charging",
    "evcharger_charging_state"
  ],
  "energy": {
    "evCharger": true
  },
  "platforms": [
    "local",
    "cloud"
  ],
  "connectivity": ["cloud"],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "pair": [
    {
      "id": "login_oauth2",
      "template": "login_oauth2",
      "options": {
        "hint": "Try again when pairing fails first time",
        "button": "Log-in"
      }
    },
		{
			"id": "list_devices",
			"template": "list_devices",
      "options": { "singular": true },
			"navigation": {
				"next": "add_devices"
			}
		},
		{
			"id": "add_devices",
			"template": "add_devices"
		}
	],
  "repair": [
    {
      "id": "login_oauth2",
      "template": "login_oauth2"
    }
  ]
}