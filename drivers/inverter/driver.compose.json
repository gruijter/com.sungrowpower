{
  "name": {
    "en": "Solar inverter",
    "nl": "PV omvormer"
  },
  "class": "solarpanel",
  "capabilities": [
    "measure_power",
    "meter_power",
    "meter_power.today"
  ],
  "capabilitiesOptions": {
    "meter_power.month": {
      "title": {
        "en": "Energy this month",
        "nl": "Energie deze maand"
      }
    },
    "meter_power.today": {
      "title": {
        "en": "Energy today",
        "nl": "Energie vandaag"
      }
    }
  },
  "platforms": [
    "local",
    "cloud"
  ],
  "connectivity": ["cloud"],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "pair": [
    {
      "id": "login_oauth2",
      "template": "login_oauth2",
      "options": {
        "hint": "Try again when pairing fails first time",
        "button": "Log-in"
      }
    },
		{
			"id": "list_devices",
			"template": "list_devices",
      "options": { "singular": true },
			"navigation": {
				"next": "add_devices"
			}
		},
		{
			"id": "add_devices",
			"template": "add_devices"
		}
	],
  "repair": [
    {
      "id": "login_oauth2",
      "template": "login_oauth2"
    }
  ]
}
